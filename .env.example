# DeepSeek OpenAI 兼容接口配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# 和风天气 API Key
QWEATHER_API_KEY=

# 腾讯位置服务 WebService API Key（天气坐标、地点搜索、地址解析共用）
TENCENT_MAP_KEY=

# 可选：循环与生成参数
# MAX_TOOL_TURNS=8
# MAX_TOKENS=1200

# 可选：输出质量自检 Evaluator-Optimizer（阶段四）
# EVAL_ENABLED 设为 false 可关闭评估（延迟敏感场景）
# EVAL_MODEL 不填则复用 DEEPSEEK_MODEL；可指向更便宜的模型做评估
# EVAL_ENABLED=true
# EVAL_MAX_RETRIES=1
# EVAL_MODEL=
# EVAL_TEMPERATURE=0.0

# 可选：MCP 接入（阶段七）
# MCP_ENABLED 设为 false 可彻底关闭 MCP，agent 只用本地工具（天气/地点/地址解析）
# MCP_CONFIG_PATH 指向要连接的 server 清单，默认项目根目录下的 mcp_servers.json
# MCP_CONNECT_TIMEOUT：单个 server 连接+握手+登记工具的总时限（秒），npx/uvx 首次下包慢可调大
# MCP_CALL_TIMEOUT：单次远程工具调用的时限（秒），超时返回结构化错误、不卡死对话
# MCP_ENABLED=true
# MCP_CONFIG_PATH=mcp_servers.json
# MCP_CONNECT_TIMEOUT=20
# MCP_CALL_TIMEOUT=30

# 可选：会话持久化（第 7 步）
# SESSION_DIR=.sessions
# SESSION_ID=default

# 可选：长期偏好持久化（阶段三）。按用户存，独立于会话，删会话不影响
# PREFERENCE_DIR=.preferences
# USER_ID=default

# 可选：日志（第 8 步）
# LOG_LEVEL=INFO
# LOG_FILE=agent.log

# 如果后续切到其他 OpenAI 兼容服务，也可以改用这些通用变量
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
