# DeepSeek OpenAI 兼容接口配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# 和风天气 API Key
QWEATHER_API_KEY=

# 腾讯位置服务 WebService API Key（天气坐标、地点搜索、地址解析共用）
TENCENT_MAP_KEY=

# 可选：循环与生成参数
# MAX_TOOL_TURNS=8
# MAX_TOKENS=1200

# 可选：会话持久化（第 7 步）
# SESSION_DIR=.sessions
# SESSION_ID=default

# 可选：日志（第 8 步）
# LOG_LEVEL=INFO
# LOG_FILE=agent.log

# 如果后续切到其他 OpenAI 兼容服务，也可以改用这些通用变量
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
